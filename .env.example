# Copy this file to .env (or run `bun run setup`, which also generates a secret).

# --- Database (libSQL) ---
# Local dev: a SQLite file, created automatically on the first `bun run db:migrate`.
DATABASE_URL=file:local.db
# Hosted (Turso): set the libsql:// URL above and the auth token below.
DATABASE_AUTH_TOKEN=

# --- Better Auth ---
ORIGIN=http://localhost:5173
# Generate a strong secret: `openssl rand -base64 32` (or run `bun run setup`).
BETTER_AUTH_SECRET=
